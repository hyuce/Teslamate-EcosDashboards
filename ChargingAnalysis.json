          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE WHEN (end_battery_level - start_battery_level) > 30 THEN 'Deep (>30pp)' ELSE 'Shallow (\u226430pp)' END AS \"Type\",\n  COUNT(*) AS \"Sessions\"\nFROM charging_processes\nWHERE car_id = $car_id\n  AND $__timeFilter(start_date)\n  AND charge_energy_added > 0\n  AND end_battery_level > start_battery_level\nGROUP BY 1",
          "refId": "A",
          "sql": {
            "columns": [
