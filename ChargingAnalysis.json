    {
      "type": "heatmap",
      "title": "Efficiency vs Temperature",
      "description": "Charging efficiency distribution by outside temperature. X-axis: outside temperature ranges. Y-axis: efficiency ranges. Color intensity = number of charging sessions.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 50
      },
      "id": 904,
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "TeslaMate"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH sessions AS (\n  SELECT\n    cp.charge_energy_added / NULLIF(cp.charge_energy_used, 0) * 100 AS efficiency,\n    cp.outside_temp_avg AS temp\n  FROM charging_processes cp\n  WHERE cp.car_id = $car_id\n    AND $__timeFilter(cp.start_date)\n    AND cp.charge_energy_used > 0\n    AND cp.charge_energy_added > 0\n    AND cp.outside_temp_avg IS NOT NULL\n),\ndata AS (\n  SELECT\n    CASE\n      WHEN temp < 10 THEN 1\n      WHEN temp < 20 THEN 2\n      ELSE 3\n    END AS temp_bucket,\n    CASE\n      WHEN efficiency < 85 THEN 1\n      WHEN efficiency < 90 THEN 2\n      WHEN efficiency < 95 THEN 3\n      WHEN efficiency < 100 THEN 4\n      ELSE 5\n    END AS eff_bucket\n  FROM sessions\n)\nSELECT\n  h.temp_label AS \"Temp\",\n  COUNT(*) FILTER (WHERE d.eff_bucket = 1) AS \"<85%\",\n  COUNT(*) FILTER (WHERE d.eff_bucket = 2) AS \"85-90%\",\n  COUNT(*) FILTER (WHERE d.eff_bucket = 3) AS \"90-95%\",\n  COUNT(*) FILTER (WHERE d.eff_bucket = 4) AS \"95-100%\",\n  COUNT(*) FILTER (WHERE d.eff_bucket = 5) AS \">100%\"\nFROM data d\nRIGHT JOIN (VALUES\n  (1, '0-10\u00b0C'),\n  (2, '10-20\u00b0C'),\n  (3, '20-30\u00b0C')\n) AS h(temp_bucket, temp_label) ON h.temp_bucket = d.temp_bucket\nGROUP BY h.temp_bucket, h.temp_label\nORDER BY h.temp_bucket",
          "refId": "A"
        }
      ],
