        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  cp.start_date AS \"Date\",\n  COALESCE(g.name, a.name, 'Unknown') AS \"Location\",\n  ROUND(cp.charge_energy_added::numeric, 1) AS \"Energy Added [kWh]\",\n  ROUND((cp.charge_energy_added / NULLIF((cp.end_battery_level - cp.start_battery_level)::numeric / 100.0, 0))::numeric, 1) AS \"Est. Capacity [kWh]\",\n  ROUND((cp.charge_energy_added / NULLIF(cp.charge_energy_used, 0) * 100)::numeric, 1) AS \"Efficiency [%]\",\n  cp.start_battery_level || '% \u2192 ' || cp.end_battery_level || '%' AS \"SOC\",\n  cp.duration_min AS \"Duration [min]\",\n  CASE WHEN EXISTS (SELECT 1 FROM charges c WHERE c.charging_process_id = cp.id AND c.fast_charger_present = true LIMIT 1) THEN 'DC' ELSE 'AC' END AS \"Type\"\nFROM charging_processes cp\nLEFT JOIN geofences g ON cp.geofence_id = g.id\nLEFT JOIN addresses a ON cp.address_id = a.id\nWHERE cp.car_id = $car_id\n  AND $__timeFilter(cp.start_date)\n  AND cp.charge_energy_added > 0\n  AND cp.end_battery_level > cp.start_battery_level\n  AND (cp.end_battery_level - cp.start_battery_level) > 10\nORDER BY cp.start_date DESC\nLIMIT 20",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
