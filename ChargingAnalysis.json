                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Deep vs Shallow Charging",
      "type": "piechart",
      "description": "Share of sessions with SOC delta above 30pp (deep \u2014 better for capacity estimates) vs. below (shallow)."
