          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND((SUM(charge_energy_added) / NULLIF(SUM(charge_energy_used), 0) * 100)::numeric, 1) AS \"Avg Efficiency [%]\"\nFROM charging_processes\nWHERE car_id = $car_id\n  AND $__timeFilter(end_date)\n  AND charge_energy_added > 0\n  AND charge_energy_used > 0",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Avg Charging Efficiency",
      "type": "stat",
      "description": "Overall charging efficiency calculated as energy added divided by energy used. Values below 100% indicate charging losses.",
      "links": [
        {
          "title": "Battery Capacity & Degradation",
