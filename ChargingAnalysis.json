          "rawSql": "SELECT ROUND((SUM(charge_energy_added) / NULLIF(SUM(charge_energy_used), 0) * 100)::numeric, 1) AS \"Avg Charging Efficiency [%]\" FROM charging_processes WHERE car_id = $car_id AND $__timeFilter(end_date) AND charge_energy_added > 0 AND charge_energy_used > 0",
